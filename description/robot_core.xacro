<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  name="robot">

    <xacro:include filename="interial_macros.xacro"/>

    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>


    <link name="base_link"></link>

    <joint name="chassis_joint" type="fixed" >
        <origin xyz="-0.1 0 0"></origin>
        <parent link="base_link"></parent>
        <child link="chassis"></child>
    </joint>

    <link name="chassis">
        <visual>
            <geometry> 
                <box size="0.3 0.3 0.15"></box>
            </geometry>
            <origin xyz="0.15 0 0.075" ></origin>
            <material  name="orange" ></material>
        </visual>
        <collision>
            <geometry> 
                <box size="0.3 0.3 0.15"></box>
            </geometry>
            <origin xyz="0.15 0 0.075" ></origin>
            <material  name="orange" ></material>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.3" y="0.3" z="0.15">
            <origin xyz="0.15 0 0.075" rpy="0 0 0"></origin>
        </xacro:inertial_box>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <origin xyz="0 0.175 0" rpy="${pi/2} 0 0"></origin>
        <parent link="base_link"></parent>
        <child link="left_wheel"></child>
        <axis xyz="0 0 -1"></axis>
    </joint>
    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.04"></cylinder>
            </geometry>
            <material name="black"></material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.04"></cylinder>
            </geometry>
            <material name="black"></material>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.05">
            <origin xyz="0 0 0" rpy="0 0 0"></origin>
        </xacro:inertial_cylinder>
    </link>
    <joint name="right_wheel_joint" type="continuous">
        <origin xyz="0 -0.175 0" rpy="${pi/2} 0 0"></origin>
        <parent link="base_link"></parent>
        <child link="right_wheel"></child>
        <axis xyz="0 0 -1"></axis>
    </joint>
    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.04"></cylinder>
            </geometry>
            <material name="black"></material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.04"></cylinder>
            </geometry>
            <material name="black"></material>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.05">
            <origin xyz="0 0 0" rpy="0 0 0"></origin>
        </xacro:inertial_cylinder>
    </link>

    <joint name="caster_wheel_joint" type="fixed">
        <origin xyz="0.25 0 0"></origin>
        <parent link="chassis"></parent>
        <child link="caster_wheel"></child>
    </joint>

    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="0.05"></sphere>
            </geometry>
            <material name="white"></material>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.05"></sphere>
            </geometry>
            <material name="white"></material>
        </collision>
        <xacro:inertial_sphere mass="0.1" radius="0.05">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>
</robot>